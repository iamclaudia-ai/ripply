{
  "name": "ripply",
  "version": "0.0.1",
  "description": "Real-time incremental map-reduce indexes for SQLite and Postgres — RavenDB-style pre-computed aggregates as a tiny standalone library",
  "license": "MIT",
  "author": "Michael & Claudia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamclaudia-ai/ripply.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "docs"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./memory": "./src/memory/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "keywords": [
    "map-reduce",
    "incremental",
    "materialized-view",
    "aggregates",
    "sqlite",
    "postgres",
    "cdc",
    "ravendb",
    "indexes"
  ]
}
